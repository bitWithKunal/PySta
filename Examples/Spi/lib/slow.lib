/*
 * Simplified Slow corner Liberty library for SPI example
 * Using simple scalar timing for guaranteed parsing
 */

library (slow) {
    delay_model : "table_lookup";
    time_unit : "1ns";
    voltage_unit : "1V";
    current_unit : "1mA";
    capacitance_unit : "1pf";

    /* Inverter - Slow corner */
    cell (INV_X1) {
        area : 1;
        pin (A) {
            direction : input;
            capacitance : 0.0022;
        }
        pin (Y) {
            direction : output;
            capacitance : 0.0033;
            function : "(!A)";
            timing () {
                related_pin : "A";
                timing_sense : negative_unate;
                cell_rise (scalar) {
                    values : "0.08";
                }
                cell_fall (scalar) {
                    values : "0.07";
                }
                rise_transition (scalar) {
                    values : "0.045";
                }
                fall_transition (scalar) {
                    values : "0.035";
                }
            }
        }
    }

    /* Buffer - Slow corner */
    cell (BUF_X1) {
        area : 1.2;
        pin (A) {
            direction : input;
            capacitance : 0.0028;
        }
        pin (Y) {
            direction : output;
            capacitance : 0.0039;
            function : "A";
            timing () {
                related_pin : "A";
                timing_sense : positive_unate;
                cell_rise (scalar) {
                    values : "0.09";
                }
                cell_fall (scalar) {
                    values : "0.08";
                }
                rise_transition (scalar) {
                    values : "0.05";
                }
                fall_transition (scalar) {
                    values : "0.045";
                }
            }
        }
    }

    /* 2-input NAND - Slow corner */
    cell (NAND2_X1) {
        area : 1.5;
        pin (A) {
            direction : input;
            capacitance : 0.0033;
        }
        pin (B) {
            direction : input;
            capacitance : 0.0033;
        }
        pin (Y) {
            direction : output;
            capacitance : 0.0044;
            function : "(!(A & B))";
            timing () {
                related_pin : "A";
                timing_sense : negative_unate;
                cell_rise (scalar) {
                    values : "0.12";
                }
                cell_fall (scalar) {
                    values : "0.09";
                }
                rise_transition (scalar) {
                    values : "0.06";
                }
                fall_transition (scalar) {
                    values : "0.045";
                }
            }
            timing () {
                related_pin : "B";
                timing_sense : negative_unate;
                cell_rise (scalar) {
                    values : "0.12";
                }
                cell_fall (scalar) {
                    values : "0.09";
                }
                rise_transition (scalar) {
                    values : "0.06";
                }
                fall_transition (scalar) {
                    values : "0.045";
                }
            }
        }
    }

    /* 2-input NOR - Slow corner */
    cell (NOR2_X1) {
        area : 1.5;
        pin (A) {
            direction : input;
            capacitance : 0.0033;
        }
        pin (B) {
            direction : input;
            capacitance : 0.0033;
        }
        pin (Y) {
            direction : output;
            capacitance : 0.0044;
            function : "(!(A | B))";
            timing () {
                related_pin : "A";
                timing_sense : negative_unate;
                cell_rise (scalar) {
                    values : "0.13";
                }
                cell_fall (scalar) {
                    values : "0.10";
                }
                rise_transition (scalar) {
                    values : "0.065";
                }
                fall_transition (scalar) {
                    values : "0.05";
                }
            }
        }
    }

    /* D Flip-Flop with setup/hold - Slow corner */
    cell (DFF_X1) {
        area : 5;
        ff (IQ, IQN) {
            next_state : "D";
            clocked_on : "CK";
        }
        pin (CK) {
            direction : input;
            capacitance : 0.0045;
            clock : true;
        }
        pin (D) {
            direction : input;
            capacitance : 0.0035;
        }
        pin (Q) {
            direction : output;
            capacitance : 0.0055;
            function : "IQ";
            timing () {
                related_pin : "CK";
                timing_type : rising_edge;
                cell_rise (scalar) {
                    values : "0.22";
                }
                cell_fall (scalar) {
                    values : "0.20";
                }
                rise_transition (scalar) {
                    values : "0.08";
                }
                fall_transition (scalar) {
                    values : "0.07";
                }
            }
        }
        pin (QN) {
            direction : output;
            capacitance : 0.0055;
            function : "IQN";
            timing () {
                related_pin : "CK";
                timing_type : rising_edge;
                cell_rise (scalar) {
                    values : "0.23";
                }
                cell_fall (scalar) {
                    values : "0.21";
                }
                rise_transition (scalar) {
                    values : "0.085";
                }
                fall_transition (scalar) {
                    values : "0.075";
                }
            }
        }
        /* Setup time - Slow corner */
        timing () {
            related_pin : "CK";
            timing_type : setup_rising;
            rise_constraint (scalar) {
                values : "0.15";
            }
            fall_constraint (scalar) {
                values : "0.15";
            }
        }
        /* Hold time - Slow corner */
        timing () {
            related_pin : "CK";
            timing_type : hold_rising;
            rise_constraint (scalar) {
                values : "0.08";
            }
            fall_constraint (scalar) {
                values : "0.08";
            }
        }
    }
}